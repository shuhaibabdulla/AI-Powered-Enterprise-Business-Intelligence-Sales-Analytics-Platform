    "# ================================================\n",
    "# CELL 5: FORECAST NEXT 3 MONTHS (FUTURE, UNKNOWN)\n",
    "# Retrain on FULL dataset, then predict forward\n",
    "# ================================================\n",
    "\n",
    "# Retrain on ALL available data (train + test)\n",
    "# Why: now that we've validated the model works,\n",
    "# we use every data point to make the best future forecast\n",
    "X_full = monthly[['time_index']]\n",
    "y_full = monthly['revenue']\n",
    "\n",
    "final_model = LinearRegression()\n",
    "final_model.fit(X_full, y_full)\n",
    "\n",
    "# Build future time indices (next 3 months after last known month)\n",
    "last_index = monthly['time_index'].max()\n",
    "future_indices = pd.DataFrame({\n",
    "    'time_index': [last_index + 1, last_index + 2, last_index + 3]\n",
    "})\n",
    "\n",
    "# Build future month labels\n",
    "last_month = monthly['month'].max()\n",
    "future_months = pd.date_range(\n",
    "    start=last_month + pd.DateOffset(months=1),\n",
    "    periods=3,\n",
    "    freq='MS'\n",
    ")\n",
    "\n",
    "# Predict\n",
    "future_predictions = final_model.predict(future_indices)\n",
    "\n",
    "# Build results table\n",
    "forecast_results = pd.DataFrame({\n",
    "    'month': future_months.strftime('%Y-%m'),\n",
    "    'predicted_revenue': future_predictions\n",
    "})\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"   📈 REVENUE FORECAST — NEXT 3 MONTHS\")\n",
    "print(\"=\" * 50)\n",
    "for _, row in forecast_results.iterrows():\n",
    "    print(f\"   {row['month']}:  R$ {row['predicted_revenue']:,.2f}\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# ---- Chart: Historical + Forecast ----\n",
    "fig, ax = plt.subplots(figsize=(14, 6))\n",
    "\n",
    "ax.plot(\n",
    "    monthly['month'], monthly['revenue'],\n",
    "    color='#2563EB', linewidth=2.5, marker='o',\n",
    "    markersize=5, label='Historical Revenue'\n",
    ")\n",
    "ax.plot(\n",
    "    future_months, future_predictions,\n",
    "    color='#f97316', linewidth=2.5, marker='D',\n",
    "    markersize=8, linestyle='--', label='Forecasted Revenue'\n",
    ")\n",
    "\n",
    "# Connect last actual point to first forecast point\n",
    "ax.plot(\n",
    "    [monthly['month'].iloc[-1], future_months[0]],\n",
    "    [monthly['revenue'].iloc[-1], future_predictions[0]],\n",
    "    color='#f97316', linewidth=2.5, linestyle='--'\n",
    ")\n",
