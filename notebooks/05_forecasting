    "# ================================================\n",
    "# CELL 3: TRAIN/TEST SPLIT (TIME-BASED) + TRAIN MODEL\n",
    "# RULE: Never shuffle time series data.\n",
    "# Train on the PAST, test on the FUTURE.\n",
    "# ================================================\n",
    "\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.metrics import mean_absolute_error, mean_absolute_percentage_error\n",
    "\n",
    "# Use last 3 months as TEST set, everything before as TRAIN\n",
    "test_size = 3\n",
    "train = monthly.iloc[:-test_size].copy()\n",
    "test  = monthly.iloc[-test_size:].copy()\n",
    "\n",
    "print(f\"Train months: {len(train)}  ({train['month'].min().strftime('%Y-%m')} → {train['month'].max().strftime('%Y-%m')})\")\n",
    "print(f\"Test months:  {len(test)}   ({test['month'].min().strftime('%Y-%m')} → {test['month'].max().strftime('%Y-%m')})\")\n",
    "print()\n",
    "\n",
    "# Features (X) = time_index only (simple model)\n",
    "# Target (y) = revenue\n",
    "X_train = train[['time_index']]\n",
    "y_train = train['revenue']\n",
    "X_test  = test[['time_index']]\n",
    "y_test  = test['revenue']\n",
    "\n",
    "# Train Linear Regression model\n",
    "model = LinearRegression()\n",
    "model.fit(X_train, y_train)\n",
    "\n",
    "print(\"✅ Model trained\")\n",
    "print(f\"   Slope (revenue growth per month): R$ {model.coef_[0]:,.2f}\")\n",
    "print(f\"   Intercept: R$ {model.intercept_:,.2f}\")\n",
    "\n",
    "# Predict on test set\n",
    "y_pred = model.predict(X_test)\n",
    "\n",
    "# Evaluate accuracy\n",
    "mae  = mean_absolute_error(y_test, y_pred)\n",
    "mape = mean_absolute_percentage_error(y_test, y_pred) * 100\n",
    "\n",
    "print()\n",
    "print(\"=\" * 50)\n",
    "print(\"   MODEL ACCURACY ON TEST SET\")\n",
    "print(\"=\" * 50)\n",
    "print(f\"   Mean Absolute Error (MAE):  R$ {mae:,.2f}\")\n",
    "print(f\"   Mean Abs % Error (MAPE):       {mape:.1f}%\")\n",
    "print()\n",
    "print(\"   ACTUAL vs PREDICTED:\")\n",
    "for i in range(len(test)):\n",
    "    month = test['month'].iloc[i].strftime('%Y-%m')\n",
    "    actual = y_test.iloc[i]\n",
    "    predicted = y_pred[i]\n",
    "    diff_pct = (predicted - actual) / actual * 100\n",
    "    print(f\"   {month}:  Actual R${actual:,.0f}   Predicted R${predicted:,.0f}   ({diff_pct:+.1f}%)\")"
   ]
