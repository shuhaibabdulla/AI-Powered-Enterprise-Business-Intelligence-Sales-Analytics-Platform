    "# ================================================\n",
    "# CELL 2: REVENUE KPIs\n",
    "# These are the numbers CEO looks at every month\n",
    "# ================================================\n",
    "\n",
    "# ---- BASE: Join orders + items ----\n",
    "orders_items = order_items.merge(\n",
    "    orders[['order_id', 'customer_id',\n",
    "            'order_status', 'order_purchase_timestamp',\n",
    "            'order_year', 'order_month', 'order_quarter']],\n",
    "    on='order_id', how='left'\n",
    ")\n",
    "\n",
    "# ---- KPI 1: Total Revenue ----\n",
    "total_revenue = orders_items['total_revenue'].sum()\n",
    "\n",
    "# ---- KPI 2: Total Orders ----\n",
    "total_orders = orders['order_id'].nunique()\n",
    "\n",
    "# ---- KPI 3: Average Order Value (AOV) ----\n",
    "# AOV = Total Revenue / Total Orders\n",
    "aov = (\n",
    "    orders_items\n",
    "    .groupby('order_id')['total_revenue']\n",
    "    .sum()\n",
    "    .mean()\n",
    ")\n",
    "\n",
    "# ---- KPI 4: Revenue by Year ----\n",
    "yearly_revenue = (\n",
    "    orders_items\n",
    "    .groupby('order_year')['total_revenue']\n",
    "    .sum()\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "# ---- KPI 5: Year over Year Growth ----\n",
    "if len(yearly_revenue) >= 2:\n",
    "    rev_2017 = yearly_revenue[\n",
    "        yearly_revenue['order_year'] == 2017\n",
    "    ]['total_revenue'].values[0]\n",
    "    rev_2018 = yearly_revenue[\n",
    "        yearly_revenue['order_year'] == 2018\n",
    "    ]['total_revenue'].values[0]\n",
    "    yoy_growth = ((rev_2018 - rev_2017) / rev_2017) * 100\n",
    "else:\n",
    "    yoy_growth = 0\n",
    "\n",
    "# ---- KPI 6: Revenue per Customer ----\n",
    "total_unique_customers = customers['customer_unique_id'].nunique()\n",
    "revenue_per_customer = total_revenue / total_unique_customers\n",
    "\n",
    "# ---- KPI 7: Monthly Revenue Growth ----\n",
    "monthly_revenue = (\n",
    "    orders_items\n",
    "    .groupby(['order_year', 'order_month'])['total_revenue']\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .sort_values(['order_year', 'order_month'])\n",
    ")\n",
    "monthly_revenue['mom_growth'] = (\n",
    "    monthly_revenue['total_revenue'].pct_change() * 100\n",
    ")\n",
    "avg_mom_growth = monthly_revenue['mom_growth'].mean()\n",
    "\n",
    "# ---- PRINT ALL REVENUE KPIs ----\n",
    "print(\"=\" * 55)\n",
    "print(\"   💰 REVENUE KPIs\")\n",
    "print(\"=\" * 55)\n",
    "print(f\"   Total Revenue:              R$ {total_revenue:>12,.2f}\")\n",
    "print(f\"   Total Orders:                  {total_orders:>12,}\")\n",
    "print(f\"   Average Order Value (AOV):  R$ {aov:>12,.2f}\")\n",
    "print(f\"   Revenue per Customer:       R$ {revenue_per_customer:>12,.2f}\")\n",
    "print(f\"   Avg Month-over-Month Growth:   {avg_mom_growth:>11.1f}%\")\n",
    "print()\n",
    "print(\"   YEARLY REVENUE BREAKDOWN:\")\n",
    "for _, row in yearly_revenue.iterrows():\n",
    "    print(f\"   {int(row['order_year'])}:  R$ {row['total_revenue']:>12,.2f}\")\n",
    "print(f\"\\n   YoY Growth (2017→2018):        {yoy_growth:>11.1f}%\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "# ---- CHART: Yearly Revenue ----\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "bars = ax.bar(\n",
    "    yearly_revenue['order_year'].astype(str),\n",
    "    yearly_revenue['total_revenue'],\n",
    "    color=['#2563EB', '#3b82f6', '#60a5fa'],\n",
    "    edgecolor='white',\n",
    "    width=0.4\n",
    ")\n",
    "for bar, val in zip(bars, yearly_revenue['total_revenue']):\n",
    "    ax.text(\n",
    "        bar.get_x() + bar.get_width()/2,\n",
    "        bar.get_height() + 50000,\n",
    "        f'R${val/1e6:.1f}M',\n",
    "        ha='center',\n",
    "        fontsize=12,\n",
    "        fontweight='bold'\n",
    "    )\n",
    "ax.set_title('Total Revenue by Year',\n",
    "             fontsize=16, fontweight='bold', pad=15)\n",
    "ax.set_xlabel('Year')\n",
    "ax.set_ylabel('Revenue (R$)')\n",
    "ax.yaxis.set_major_formatter(\n",
    "    mticker.FuncFormatter(lambda x, _: f'R${x/1e6:.0f}M')\n",
    ")\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/charts/kpi_yearly_revenue.png',\n",
    "            dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
