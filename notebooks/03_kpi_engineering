    "# ================================================\n",
    "# CELL 3 FIXED: CUSTOMER KPIs - CLEAN CHARTS\n",
    "# ================================================\n",
    "\n",
    "# ---- Base: customer + orders + revenue ----\n",
    "customer_orders = (\n",
    "    orders_items\n",
    "    .merge(\n",
    "        customers[['customer_id', 'customer_unique_id',\n",
    "                   'customer_city', 'customer_state']],\n",
    "        on='customer_id', how='left'\n",
    "    )\n",
    "    .groupby('customer_unique_id')\n",
    "    .agg(\n",
    "        total_spent    = ('total_revenue', 'sum'),\n",
    "        total_orders   = ('order_id',      'nunique'),\n",
    "        first_order    = ('order_purchase_timestamp', 'min'),\n",
    "        last_order     = ('order_purchase_timestamp', 'max'),\n",
    "        avg_order_val  = ('total_revenue', 'mean'),\n",
    "    )\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "customer_orders['first_order'] = pd.to_datetime(customer_orders['first_order'])\n",
    "customer_orders['last_order']  = pd.to_datetime(customer_orders['last_order'])\n",
    "\n",
    "# ---- KPIs ----\n",
    "avg_clv          = customer_orders['total_spent'].mean()\n",
    "median_clv       = customer_orders['total_spent'].median()\n",
    "top_clv          = customer_orders['total_spent'].max()\n",
    "repeat_customers = (customer_orders['total_orders'] > 1).sum()\n",
    "total_customers  = len(customer_orders)\n",
    "repeat_rate      = repeat_customers / total_customers * 100\n",
    "single_customers = (customer_orders['total_orders'] == 1).sum()\n",
    "single_rate      = single_customers / total_customers * 100\n",
    "\n",
    "# ---- Segments ----\n",
    "customer_orders['segment'] = pd.cut(\n",
    "    customer_orders['total_spent'],\n",
    "    bins=[0, 100, 300, 600, 1000, float('inf')],\n",
    "    labels=['Bronze', 'Silver', 'Gold', 'Platinum', 'Diamond']\n",
    ")\n",
    "segment_counts = customer_orders['segment'].value_counts().sort_index()\n",
    "\n",
    "# ---- PRINT KPIs ----\n",
    "print(\"=\" * 55)\n",
    "print(\"   👥 CUSTOMER KPIs\")\n",
    "print(\"=\" * 55)\n",
    "print(f\"   Total Unique Customers:      {total_customers:>10,}\")\n",
    "print(f\"   Avg Customer Lifetime Value: R$ {avg_clv:>9,.2f}\")\n",
    "print(f\"   Median CLV:                  R$ {median_clv:>9,.2f}\")\n",
    "print(f\"   Highest CLV:                 R$ {top_clv:>9,.2f}\")\n",
    "print()\n",
    "print(f\"   Repeat Purchase Rate:           {repeat_rate:>9.1f}%\")\n",
    "print(f\"   Single Purchase Customers:      {single_rate:>9.1f}%\")\n",
    "print(f\"   Repeat Customers:            {repeat_customers:>10,}\")\n",
