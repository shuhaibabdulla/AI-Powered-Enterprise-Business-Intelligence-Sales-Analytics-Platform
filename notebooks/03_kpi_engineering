    "for seg, count in segment_counts.items():\n",
    "    pct = count / total_customers * 100\n",
    "    print(f\"   {seg:<12} {count:>8,}  ({pct:.1f}%)\")\n",
    "print(\"=\" * 55)\n",
    "\n",
