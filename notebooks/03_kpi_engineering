    "# ================================================\n",
    "# CELL 4: SELLER PERFORMANCE KPIs\n",
    "# Business Question: Which sellers perform best?\n",
    "# Which sellers deliver late?\n",
    "# ================================================\n",
    "\n",
    "# Join order_items + orders + sellers\n",
    "seller_data = (\n",
    "    order_items\n",
    "    .merge(\n",
    "        orders[['order_id', 'order_status',\n",
    "                'delivery_days', 'is_late_delivery']],\n",
    "        on='order_id', how='left'\n",
    "    )\n",
    "    .merge(\n",
    "        sellers[['seller_id', 'seller_city', 'seller_state']],\n",
    "        on='seller_id', how='left'\n",
    "    )\n",
    ")\n",
    "\n",
    "# ---- KPI: Seller Performance Summary ----\n",
    "seller_kpis = (\n",
    "    seller_data\n",
    "    .groupby('seller_id')\n",
    "    .agg(\n",
    "        total_revenue    = ('total_revenue',    'sum'),\n",
    "        total_orders     = ('order_id',         'nunique'),\n",
    "        avg_order_value  = ('total_revenue',    'mean'),\n",
    "        avg_delivery_days= ('delivery_days',    'mean'),\n",
    "        late_deliveries  = ('is_late_delivery', 'sum'),\n",
    "        total_deliveries = ('is_late_delivery', 'count'),\n",
    "    )\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "# Late delivery rate per seller\n",
    "seller_kpis['late_rate'] = (\n",
    "    seller_kpis['late_deliveries'] /\n",
    "    seller_kpis['total_deliveries'] * 100\n",
    ").round(2)\n",
    "\n",
    "# ---- Top 10 Sellers by Revenue ----\n",
    "top_sellers = (\n",
    "    seller_kpis\n",
    "    .sort_values('total_revenue', ascending=False)\n",
    "    .head(10)\n",
    ")\n",
    "\n",
    "# ---- Worst 10 Sellers by Late Rate ----\n",
    "worst_sellers = (\n",
    "    seller_kpis[seller_kpis['total_deliveries'] >= 10]\n",
    "    .sort_values('late_rate', ascending=False)\n",
    "    .head(10)\n",
    ")\n",
    "\n",
    "# ---- PRINT KPIs ----\n",
    "print(\"=\" * 55)\n",
    "print(\"   📦 SELLER PERFORMANCE KPIs\")\n",
    "print(\"=\" * 55)\n",
    "print(f\"   Total Sellers:              {len(seller_kpis):>10,}\")\n",
    "print(f\"   Avg Revenue per Seller:  R$ {seller_kpis['total_revenue'].mean():>10,.2f}\")\n",
    "print(f\"   Avg Delivery Days:          {seller_kpis['avg_delivery_days'].mean():>10.1f}\")\n",
    "print(f\"   Avg Late Rate:              {seller_kpis['late_rate'].mean():>10.1f}%\")\n",
    "print()\n",
    "print(\"   TOP 5 SELLERS BY REVENUE:\")\n",
    "for i, row in top_sellers.head(5).iterrows():\n",
    "    print(f\"   {row['seller_id'][:12]}...  \"\n",
    "          f\"R$ {row['total_revenue']:>9,.2f}  \"\n",
    "          f\"({row['total_orders']} orders)\")\n",
    "print()\n",
    "print(\"   WORST 5 SELLERS BY LATE DELIVERY:\")\n",
    "for i, row in worst_sellers.head(5).iterrows():\n",
