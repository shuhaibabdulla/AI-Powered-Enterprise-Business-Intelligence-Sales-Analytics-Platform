    "# ================================================\n",
    "# CELL 6: CLEAN THE ORDERS TABLE\n",
    "# Fix 1: Convert date columns from text to datetime\n",
    "# Fix 2: Handle missing values properly\n",
    "# Fix 3: Add useful new columns for analysis\n",
    "# ================================================\n",
    "\n",
    "# Step 1: Make a copy - NEVER change original data\n",
    "orders_clean = orders.copy()\n",
    "\n",
    "# Step 2: Fix date columns - convert text to real dates\n",
    "date_columns = [\n",
    "    'order_purchase_timestamp',\n",
    "    'order_approved_at',\n",
    "    'order_delivered_carrier_date',\n",
    "    'order_delivered_customer_date',\n",
    "    'order_estimated_delivery_date'\n",
    "]\n",
    "\n",
    "for col in date_columns:\n",
    "    orders_clean[col] = pd.to_datetime(orders_clean[col], errors='coerce')\n",
    "    # errors='coerce' means: if date is invalid, make it NaT (empty date)\n",
    "\n",
    "print(\"✅ Step 1: Date columns fixed\")\n",
    "\n",
    "# Step 3: Add year, month, quarter columns\n",
    "# These help us analyze sales by time period\n",
    "orders_clean['order_year']    = orders_clean['order_purchase_timestamp'].dt.year\n",
    "orders_clean['order_month']   = orders_clean['order_purchase_timestamp'].dt.month\n",
    "orders_clean['order_quarter'] = orders_clean['order_purchase_timestamp'].dt.quarter\n",
    "orders_clean['order_day']     = orders_clean['order_purchase_timestamp'].dt.day_name()\n",
    "\n",
    "print(\"✅ Step 2: Year/Month/Quarter columns added\")\n",
    "\n",
    "# Step 4: Calculate delivery time in days\n",
    "# How many days from purchase to delivery?\n",
    "orders_clean['delivery_days'] = (\n",
    "    orders_clean['order_delivered_customer_date'] -\n",
    "    orders_clean['order_purchase_timestamp']\n",
    ").dt.days\n",
    "\n",
    "print(\"✅ Step 3: Delivery days calculated\")\n",
    "\n",
    "# Step 5: Flag late deliveries\n",
    "# Was order delivered after promised date?\n",
    "orders_clean['is_late_delivery'] = (\n",
    "    orders_clean['order_delivered_customer_date'] >\n",
    "    orders_clean['order_estimated_delivery_date']\n",
    ").astype(int)  # 1 = late, 0 = on time\n",
    "\n",
    "print(\"✅ Step 4: Late delivery flag added\")\n",
    "\n",
    "# Show results\n",
    "print()\n",
    "print(\"NEW COLUMNS ADDED:\")\n",
    "new_cols = ['order_year', 'order_month', 'order_quarter', \n",
    "            'order_day', 'delivery_days', 'is_late_delivery']\n",
    "print(orders_clean[new_cols].head(5))\n",
    "print()\n",
    "print(f\"Orders cleaned: {len(orders_clean):,} rows\")"
   ]
