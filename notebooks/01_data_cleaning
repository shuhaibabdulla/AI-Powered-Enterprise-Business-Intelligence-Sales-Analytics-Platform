    "# ================================================\n",
    "# CELL 7: CLEAN ORDER ITEMS TABLE\n",
    "# This table has PRICE and FREIGHT (shipping cost)\n",
    "# Revenue = price + freight_value\n",
    "# ================================================\n",
    "\n",
    "# Step 1: Copy original\n",
    "order_items_clean = order_items.copy()\n",
    "\n",
    "print(\"BEFORE CLEANING:\")\n",
    "print(f\"Rows: {len(order_items_clean):,}\")\n",
    "print()\n",
    "\n",
    "# Step 2: Check for nulls\n",
    "print(\"MISSING VALUES:\")\n",
    "nulls = order_items_clean.isnull().sum()\n",
    "for col, count in nulls.items():\n",
    "    status = \"⚠️ \" if count > 0 else \"✅\"\n",
    "    print(f\"{status} {col:<30} {count}\")\n",
    "\n",
    "# Step 3: Remove rows where price is missing or zero\n",
    "before = len(order_items_clean)\n",
    "order_items_clean = order_items_clean[order_items_clean['price'] > 0]\n",
    "after = len(order_items_clean)\n",
    "print(f\"\\n✅ Step 1: Removed {before - after} invalid prices\")\n",
    "\n",
    "# Step 4: Fill missing freight with 0\n",
    "order_items_clean['freight_value'] = order_items_clean['freight_value'].fillna(0)\n",
    "print(\"✅ Step 2: Missing freight filled with 0\")\n",
    "\n",
    "# Step 5: Calculate total revenue per item\n",
    "order_items_clean['total_revenue'] = (\n",
    "    order_items_clean['price'] + \n",
    "    order_items_clean['freight_value']\n",
    ")\n",
    "print(\"✅ Step 3: Total revenue calculated\")\n",
    "\n",
    "# Step 6: Fix shipping date column\n",
    "order_items_clean['shipping_limit_date'] = pd.to_datetime(\n",
    "    order_items_clean['shipping_limit_date'], errors='coerce'\n",
