    "# ================================================\n",
    "# CELL 3: BUILD DATE DIMENSION TABLE\n",
    "# Power BI needs a proper \"calendar table\" to\n",
    "# do time-based calculations (YTD, QTD, MoM)\n",
    "# ================================================\n",
    "\n",
    "# Get full date range covering all orders\n",
    "start_date = orders['order_purchase_timestamp'].min().normalize()\n",
    "end_date   = orders['order_purchase_timestamp'].max().normalize()\n",
    "\n",
    "date_dim = pd.DataFrame({\n",
    "    'date': pd.date_range(start=start_date, end=end_date, freq='D')\n",
    "})\n",
    "\n",
    "date_dim['year']         = date_dim['date'].dt.year\n",
    "date_dim['month']        = date_dim['date'].dt.month\n",
    "date_dim['month_name']   = date_dim['date'].dt.month_name()\n",
    "date_dim['quarter']      = date_dim['date'].dt.quarter\n",
    "date_dim['day']          = date_dim['date'].dt.day\n",
    "date_dim['day_name']     = date_dim['date'].dt.day_name()\n",
    "date_dim['week']         = date_dim['date'].dt.isocalendar().week\n",
    "date_dim['is_weekend']   = date_dim['date'].dt.dayofweek.isin([5, 6]).astype(int)\n",
    "date_dim['year_month']   = date_dim['date'].dt.strftime('%Y-%m')\n",
    "date_dim['year_quarter'] = (\n",
    "    date_dim['year'].astype(str) + '-Q' + date_dim['quarter'].astype(str)\n",
    ")\n",
    "\n",
    "print(\"✅ DATE DIMENSION TABLE BUILT\")\n",
    "print(f\"   Date Range: {start_date.date()} → {end_date.date()}\")\n",
    "print(f\"   Total Days: {len(date_dim):,}\")\n",
    "print()\n",
    "date_dim.head(5)"
   ]
