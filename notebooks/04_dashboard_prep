    "# ================================================\n",
    "# CELL 2: BUILD MASTER FACT TABLE\n",
    "# One row = one product sold in one order\n",
    "# This single table powers Power BI + Streamlit\n",
    "# ================================================\n",
    "\n",
    "fact_table = (\n",
    "    order_items\n",
    "    .merge(\n",
    "        orders[['order_id', 'customer_id', 'order_status',\n",
    "                'order_purchase_timestamp', 'order_approved_at',\n",
    "                'order_delivered_customer_date',\n",
    "                'order_estimated_delivery_date',\n",
    "                'order_year', 'order_month', 'order_quarter',\n",
    "                'order_day', 'delivery_days', 'is_late_delivery']],\n",
    "        on='order_id', how='left'\n",
    "    )\n",
    "    .merge(\n",
    "        customers[['customer_id', 'customer_unique_id',\n",
    "                   'customer_city', 'customer_state']],\n",
    "        on='customer_id', how='left'\n",
    "    )\n",
    "    .merge(\n",
    "        products[['product_id', 'product_category_name_english',\n",
    "                  'product_weight_g']],\n",
    "        on='product_id', how='left'\n",
    "    )\n",
    "    .merge(\n",
    "        sellers[['seller_id', 'seller_city', 'seller_state']],\n",
    "        on='seller_id', how='left'\n",
    "    )\n",
    ")\n",
    "\n",
    "# Rename category column for clarity\n",
    "fact_table = fact_table.rename(\n",
    "    columns={'product_category_name_english': 'product_category'}\n",
    ")\n",
    "\n",
    "print(\"✅ MASTER FACT TABLE BUILT\")\n",
    "print(f\"   Total Rows:    {len(fact_table):,}\")\n",
    "print(f\"   Total Columns: {fact_table.shape[1]}\")\n",
    "print()\n",
    "print(\"COLUMNS:\")\n",
    "for col in fact_table.columns:\n",
    "    print(f\"   → {col}\")\n",
    "print()\n",
    "fact_table.head(3)"
   ]
