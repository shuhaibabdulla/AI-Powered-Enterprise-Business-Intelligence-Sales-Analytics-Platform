    "# ================================================\n",
    "# CELL 1: LOAD LIBRARIES AND CLEANED DATA\n",
    "# ================================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mticker\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Make charts look professional\n",
    "plt.rcParams['figure.figsize'] = (12, 5)\n",
    "plt.rcParams['font.size'] = 12\n",
    "plt.rcParams['axes.spines.top'] = False\n",
    "plt.rcParams['axes.spines.right'] = False\n",
    "\n",
    "# Load all cleaned data\n",
    "orders      = pd.read_csv('../data/processed/orders_clean.csv')\n",
    "order_items = pd.read_csv('../data/processed/order_items_clean.csv')\n",
    "customers   = pd.read_csv('../data/processed/customers_clean.csv')\n",
    "products    = pd.read_csv('../data/processed/products_clean.csv')\n",
    "payments    = pd.read_csv('../data/processed/payments_clean.csv')\n",
    "reviews     = pd.read_csv('../data/processed/reviews_clean.csv')\n",
    "\n",
    "# Fix date columns after loading\n",
    "orders['order_purchase_timestamp'] = pd.to_datetime(\n",
    "    orders['order_purchase_timestamp']\n",
    ")\n",
    "\n",
    "print(\"✅ All libraries loaded\")\n",
    "print(\"✅ All cleaned data loaded\")\n",
    "print(f\"✅ Orders: {len(orders):,}\")\n",
    "print(f\"✅ Order Items: {len(order_items):,}\")\n",
    "print(f\"✅ Customers: {len(customers):,}\")"
   ]
