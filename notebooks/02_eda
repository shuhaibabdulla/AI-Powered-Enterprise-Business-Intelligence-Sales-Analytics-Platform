    "# ================================================\n",
    "# CELL 6: PAYMENT METHODS + CUSTOMER REVIEW SCORES\n",
    "# Business Question: How do customers pay?\n",
    "# Business Question: Are customers happy?\n",
    "# ================================================\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# ---- CHART 1: Payment Methods ----\n",
    "payment_counts = (\n",
    "    payments\n",
    "    .groupby('payment_type')['payment_value']\n",
    "    .sum()\n",
    "    .sort_values(ascending=False)\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "# Clean payment type names\n",
    "payment_counts['payment_type'] = (\n",
    "    payment_counts['payment_type']\n",
    "    .str.replace('_', ' ')\n",
    "    .str.title()\n",
    ")\n",
    "\n",
    "colors_pay = ['#2563EB', '#3b82f6', '#60a5fa', '#93c5fd']\n",
    "\n",
    "axes[0].bar(\n",
    "    payment_counts['payment_type'],\n",
    "    payment_counts['payment_value'],\n",
    "    color=colors_pay,\n",
    "    edgecolor='white',\n",
    "    width=0.5\n",
    ")\n",
    "\n",
    "# Value labels on bars\n",
    "for i, (_, row) in enumerate(payment_counts.iterrows()):\n",
    "    axes[0].text(\n",
    "        i,\n",
    "        row['payment_value'] + 50000,\n",
    "        f\"R${row['payment_value']/1e6:.1f}M\",\n",
    "        ha='center',\n",
    "        fontsize=10,\n",
    "        fontweight='bold'\n",
    "    )\n",
    "\n",
    "axes[0].set_title('Revenue by Payment Method',\n",
    "                  fontsize=14, fontweight='bold')\n",
    "axes[0].set_xlabel('Payment Type')\n",
    "axes[0].set_ylabel('Total Value (R$)')\n",
    "axes[0].yaxis.set_major_formatter(\n",
    "    mticker.FuncFormatter(lambda x, _: f'R${x/1e6:.0f}M')\n",
    ")\n",
    "\n",
    "# ---- CHART 2: Review Score Distribution ----\n",
    "review_counts = (\n",
    "    reviews['review_score']\n",
    "    .value_counts()\n",
    "    .sort_index()\n",
    ")\n",
    "\n",
    "score_colors = {\n",
    "    1: '#ef4444',  # red = bad\n",
    "    2: '#f97316',  # orange\n",
    "    3: '#eab308',  # yellow\n",
    "    4: '#22c55e',  # green\n",
    "    5: '#2563EB'   # blue = great\n",
    "}\n",
    "\n",
    "bars = axes[1].bar(\n",
    "    review_counts.index,\n",
    "    review_counts.values,\n",
    "    color=[score_colors[i] for i in review_counts.index],\n",
    "    edgecolor='white',\n",
    "    width=0.5\n",
    ")\n",
    "\n",
    "# Value labels\n",
    "for bar, val in zip(bars, review_counts.values):\n",
