    "# ================================================\n",
    "# CELL 5: DELIVERY TIME ANALYSIS\n",
    "# Business Question: How long do deliveries take?\n",
    "# And what is our late delivery rate?\n",
    "# ================================================\n",
    "\n",
    "# Filter only delivered orders with valid delivery days\n",
    "delivered = orders[\n",
    "    (orders['order_status'] == 'delivered') &\n",
    "    (orders['delivery_days'] > 0) &\n",
    "    (orders['delivery_days'] < 100)  # remove extreme outliers\n",
    "].copy()\n",
    "\n",
    "# ---- CHART 1: Delivery Days Distribution ----\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Histogram\n",
    "axes[0].hist(\n",
    "    delivered['delivery_days'],\n",
    "    bins=40,\n",
    "    color='#2563EB',\n",
    "    edgecolor='white',\n",
    "    alpha=0.85\n",
    ")\n",
    "axes[0].axvline(\n",
    "    delivered['delivery_days'].mean(),\n",
    "    color='red',\n",
    "    linewidth=2,\n",
    "    linestyle='--',\n",
    "    label=f\"Average: {delivered['delivery_days'].mean():.1f} days\"\n",
    ")\n",
    "axes[0].axvline(\n",
    "    delivered['delivery_days'].median(),\n",
    "    color='orange',\n",
    "    linewidth=2,\n",
    "    linestyle='--',\n",
    "    label=f\"Median: {delivered['delivery_days'].median():.1f} days\"\n",
    ")\n",
    "axes[0].set_title('Delivery Time Distribution',\n",
    "                  fontsize=14, fontweight='bold')\n",
    "axes[0].set_xlabel('Days to Deliver')\n",
    "axes[0].set_ylabel('Number of Orders')\n",
    "axes[0].legend()\n",
    "\n",
    "# ---- CHART 2: Late vs On Time Pie Chart ----\n",
    "late_count   = delivered['is_late_delivery'].sum()\n",
    "ontime_count = len(delivered) - late_count\n",
    "late_pct     = late_count / len(delivered) * 100\n",
    "\n",
    "axes[1].pie(\n",
    "    [ontime_count, late_count],\n",
    "    labels=[\n",
    "        f'On Time\\n{100-late_pct:.1f}%',\n",
    "        f'Late\\n{late_pct:.1f}%'\n",
    "    ],\n",
    "    colors=['#2563EB', '#ef4444'],\n",
    "    autopct='%1.1f%%',\n",
    "    startangle=90,\n",
    "    textprops={'fontsize': 12}\n",
    ")\n",
    "axes[1].set_title('Late vs On-Time Deliveries',\n",
    "                  fontsize=14, fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/charts/delivery_analysis.png',\n",
    "            dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# Print numbers\n",
    "print(\"DELIVERY TIME ANALYSIS:\")\n",
    "print(\"=\"*45)\n",
    "print(f\"  Total Delivered Orders:  {len(delivered):,}\")\n",
    "print(f\"  Average Delivery Time:   {delivered['delivery_days'].mean():.1f} days\")\n",
    "print(f\"  Fastest Delivery:        {delivered['delivery_days'].min():.0f} days\")\n",
    "print(f\"  Slowest Delivery:        {delivered['delivery_days'].max():.0f} days\")\n",
    "print()\n",
    "print(f\"  On-Time Orders:  {ontime_count:,}  ({100-late_pct:.1f}%)\")\n",
    "print(f\"  Late Orders:     {late_count:,}  ({late_pct:.1f}%)\")"
   ]
