    "# ================================================\n",
    "# CELL 2: MONTHLY REVENUE TREND\n",
    "# Business Question: Which months have most sales?\n",
    "# ================================================\n",
    "\n",
    "# Step 1: Join orders with order_items to get revenue\n",
    "orders_revenue = order_items.merge(\n",
    "    orders[['order_id', 'order_purchase_timestamp', \n",
    "            'order_year', 'order_month']],\n",
    "    on='order_id',\n",
    "    how='left'\n",
    ")\n",
    "\n",
    "# Step 2: Group by year and month\n",
    "monthly_revenue = (\n",
    "    orders_revenue\n",
    "    .groupby(['order_year', 'order_month'])['total_revenue']\n",
    "    .sum()\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "# Step 3: Create readable month label\n",
    "monthly_revenue['period'] = (\n",
    "    monthly_revenue['order_year'].astype(str) + '-' +\n",
    "    monthly_revenue['order_month'].astype(str).str.zfill(2)\n",
    ")\n",
    "\n",
    "# Sort by time\n",
    "monthly_revenue = monthly_revenue.sort_values('period')\n",
    "\n",
    "# Step 4: Plot chart\n",
    "fig, ax = plt.subplots(figsize=(14, 5))\n",
    "\n",
    "ax.plot(\n",
    "    monthly_revenue['period'],\n",
    "    monthly_revenue['total_revenue'],\n",
    "    color='#2563EB',\n",
    "    linewidth=2.5,\n",
    "    marker='o',\n",
    "    markersize=5\n",
    ")\n",
    "\n",
    "ax.fill_between(\n",
    "    monthly_revenue['period'],\n",
    "    monthly_revenue['total_revenue'],\n",
    "    alpha=0.1,\n",
    "    color='#2563EB'\n",
    ")\n",
    "\n",
    "# Labels\n",
    "ax.set_title('Monthly Revenue Trend', fontsize=16, fontweight='bold', pad=15)\n",
    "ax.set_xlabel('Month', fontsize=12)\n",
    "ax.set_ylabel('Revenue (R$)', fontsize=12)\n",
    "ax.yaxis.set_major_formatter(\n",
    "    mticker.FuncFormatter(lambda x, _: f'R${x:,.0f}')\n",
    ")\n",
    "plt.xticks(rotation=45, ha='right')\n",
    "plt.tight_layout()\n",
    "\n",
    "# Save chart\n",
    "plt.savefig('../outputs/charts/monthly_revenue.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# Print numbers too\n",
    "print(\"\\nMONTHLY REVENUE SUMMARY:\")\n",
    "print(f\"Best Month:  {monthly_revenue.loc[monthly_revenue['total_revenue'].idxmax(), 'period']} \"\n",
    "      f\"→ R$ {monthly_revenue['total_revenue'].max():,.2f}\")\n",
    "print(f\"Worst Month: {monthly_revenue.loc[monthly_revenue['total_revenue'].idxmin(), 'period']} \"\n",
    "      f\"→ R$ {monthly_revenue['total_revenue'].min():,.2f}\")\n",
    "print(f\"Average:     R$ {monthly_revenue['total_revenue'].mean():,.2f}\")"
   ]
